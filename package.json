{
  "name": "openarena",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "npm run test:unit",
    "db:migrate": "node scripts/db-migrate.mjs",
    "mtgjson:download": "node scripts/mtgjson-download.mjs",
    "mtgjson:restore": "node scripts/mtgjson-restore.mjs",
    "mtgjson:refresh": "node scripts/mtgjson-download.mjs && node scripts/mtgjson-restore.mjs",
    "scryfall:image-map:refresh": "node scripts/scryfall-image-map-refresh.mjs",
    "cards:import": "node scripts/import-cards.mjs",
    "cards:import:resume": "node scripts/import-cards.mjs --resume",
    "test:unit": "node --experimental-strip-types --experimental-loader ./test/unit/engine/resolve-ts-loader.mjs --test \"test/unit/**/*.test.ts\"",
    "test:integration": "node --test test/integration/**/*.test.mjs",
    "test:engine": "node --experimental-strip-types --experimental-loader ./test/unit/engine/resolve-ts-loader.mjs --test test/unit/engine/*.test.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "immer": "^11.1.4",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
